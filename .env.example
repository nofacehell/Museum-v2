# --- Database (Neon Postgres) ---
# Get from https://console.neon.tech → your project → Connection string (pooled)
DATABASE_URL="postgresql://user:password@host.neon.tech/museum?sslmode=require"
# Direct (non-pooled) URL — used by Prisma migrations
DIRECT_URL="postgresql://user:password@host.neon.tech/museum?sslmode=require"

# --- Auth.js ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
# Public URL of the app (no trailing slash)
AUTH_URL="http://localhost:3000"

# --- Cloudinary ---
# Get from https://console.cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Public name exposed to the browser for the upload widget
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# --- Initial admin user (consumed by `pnpm db:seed`) ---
ADMIN_EMAIL="admin@museum.local"
ADMIN_PASSWORD="change-me-in-prod"
